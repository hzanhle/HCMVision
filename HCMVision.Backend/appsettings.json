{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=hcmc_rain_vision_dev;Username=postgres;Password=postgres"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "Port": 587,
    "SenderName": "HCMC Rain Vision Alert",
    "SenderEmail": "",
    "Password": ""
  },

  "JwtSettings": {
    "Key": "dev-only-jwt-secret-key-minimum-32-characters-long-for-hmac-sha256",
    "Issuer": "HcmcRainVisionBackend",
    "Audience": "HcmcRainVisionClient"
  },

  "CloudinarySettings": {
    "CloudName": "",
    "ApiKey": "",
    "ApiSecret": ""
  },

  "FirebaseSettings": {
    "ServiceAccountPath": ""
  },

  "GoogleMaps": {
    "ApiKey": ""
  },

  "Gemini": {
    "ApiKey": ""
  },

  "AI": {
    "Provider": "OllamaQwen",
    "EnableModel": true,
    "MaxParallelism": 1,
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "VisionModel": "qwen3-vl:2b",
      "TimeoutSeconds": 120
    },
    "RemoteQwen": {
      "BaseUrl": "",
      "ApiToken": "",
      "VisionModel": "Qwen/Qwen3-VL-4B-Instruct",
      "TimeoutSeconds": 120,
      "SessionEnabled": false,
      "ScanIntervalMinutes": 15,
      "MaxCamerasPerScan": 20,
      "DailyMaxInferences": 160,
      "SaveAllImages": false
    }
  }
